{
  "name": "@gmwalletapp/crypto-icons-react",
  "version": "1.4.1",
  "description": "React component for crypto icons — tokens, networks, exchanges, wallets via CDN",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean",
    "dev": "tsup src/index.tsx --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@gmwalletapp/crypto-icons": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "crypto",
    "icons",
    "web3",
    "react",
    "svg",
    "tokens",
    "networks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMWalletApp/crypto-icons.git",
    "directory": "packages/react"
  }
}
